<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="800.0" prefWidth="1300.0" styleClass="bg-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.NovaDashboardController">

    <stylesheets>
        <URL value="@../css/app-dark.css" />
    </stylesheets>

    <ImageView fx:id="appBackgroundImage" fitWidth="1920.0" fitHeight="1080.0" preserveRatio="false" opacity="0.03">
        <image>
            <Image url="@../images/705836.jpg" />
        </image>
    </ImageView>
    <Region fx:id="bgOverlay" styleClass="bg-background" />

    <BorderPane fx:id="mainAppUI" style="-fx-background-color: transparent;">

        <top>
            <HBox fx:id="navBar" alignment="CENTER_LEFT" prefHeight="72.0" spacing="4.0"
                  styleClass="bg-surface"
                  style="-fx-border-color: transparent transparent rgba(128,128,128,0.1) transparent;
                         -fx-border-width: 0 0 1 0;
                         -fx-padding: 0 24 0 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">

                <!-- Logo -->
                <ImageView fitHeight="52.0" preserveRatio="true" style="-fx-cursor: hand; -fx-padding: 0 16 0 0;">
                    <image><Image url="@../images/nova-logo.png" /></image>
                </ImageView>

                <!-- Nav buttons -->
                <Button fx:id="btnHome"    maxHeight="Infinity" mnemonicParsing="false" onAction="#handleShowHome"          styleClass="nav-btn, nav-btn-hub-active" style="-fx-padding: 0 16; -fx-font-size: 13px; -fx-font-weight: bold;" text="◆  Hub" />
                <Button fx:id="btnCourses" maxHeight="Infinity" mnemonicParsing="false" onAction="#handleShowStudySessions"  styleClass="nav-btn" style="-fx-padding: 0 16; -fx-font-size: 13px;" text="📚  Courses" />
                <Button fx:id="btnLibrary" maxHeight="Infinity" mnemonicParsing="false" onAction="#handleShowLibrary"        styleClass="nav-btn" style="-fx-padding: 0 16; -fx-font-size: 13px;" text="📖  Library" />
                <Button fx:id="btnForum"   maxHeight="Infinity" mnemonicParsing="false" onAction="#handleShowForum"          styleClass="nav-btn" style="-fx-padding: 0 16; -fx-font-size: 13px;" text="💬  Community" />
                <Button fx:id="btnQuiz"    maxHeight="Infinity" mnemonicParsing="false" onAction="#handleShowQuiz"           styleClass="nav-btn" style="-fx-padding: 0 16; -fx-font-size: 13px;" text="📝  Quizzes" />
                <Button fx:id="btnGames"   maxHeight="Infinity" mnemonicParsing="false" onAction="#handleShowGamification"   styleClass="nav-btn" style="-fx-padding: 0 16; -fx-font-size: 13px;" text="🎮  Play" />
                <Button fx:id="btnRewards" maxHeight="Infinity" mnemonicParsing="false" onAction="#handleShowRewards"        styleClass="nav-btn" style="-fx-padding: 0 16; -fx-font-size: 13px;" text="⭐  Rewards" />

                <Region HBox.hgrow="ALWAYS" />

                <!-- Theme + Fullscreen -->
                <Button fx:id="btnTheme" mnemonicParsing="false" onAction="#onOpenThemeSettings"
                        styleClass="text-secondary"
                        style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 18px; -fx-padding: 0 8;"
                        text="◑" />
                <Button fx:id="btnFullscreen" mnemonicParsing="false" onAction="#toggleFullscreen"
                        styleClass="text-secondary"
                        style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 18px; -fx-padding: 0 8;"
                        text="⛶" />

                <!-- Notification bell -->
                <StackPane fx:id="notificationPane" onMouseClicked="#onNotificationClick"
                           style="-fx-cursor: hand; -fx-padding: 0 8;">
                    <Label text="🔔" styleClass="text-primary" style="-fx-font-size: 20px;" />
                    <StackPane fx:id="badgePane" StackPane.alignment="TOP_RIGHT" visible="false">
                        <Circle radius="8.0" fill="#f97316"
                                style="-fx-effect: dropshadow(gaussian, rgba(249,115,22,0.6), 8, 0, 0, 2);"/>
                        <Label fx:id="notificationCount" text="0"
                               style="-fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold;" />
                        <StackPane.margin><Insets top="-2.0" right="-2.0" /></StackPane.margin>
                    </StackPane>
                </StackPane>

                <!-- Avatar -->
                <HBox alignment="CENTER" style="-fx-cursor: hand; -fx-padding: 0 0 0 8;" onMouseClicked="#onAvatarClick">
                    <StackPane fx:id="avatarPane"
                               style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 4);">
                        <Circle fx:id="circleNavAvatar" radius="22" fill="#e2e8f0" />
                        <Label fx:id="lblNavInitials" text="ST"
                               style="-fx-text-fill: #0f172a; -fx-font-weight: 900; -fx-font-size: 14px;" />
                    </StackPane>
                </HBox>
            </HBox>
        </top>

        <center>
            <StackPane fx:id="contentArea" />
        </center>
    </BorderPane>

    <StackPane fx:id="splashScreen" styleClass="bg-background">
        <VBox alignment="CENTER" spacing="40.0">
            <ImageView fx:id="splashLogo" fitHeight="140.0" preserveRatio="true">
                <image><Image url="@../images/nova-logo.png" /></image>
            </ImageView>
            <ProgressIndicator style="-fx-progress-color: #d94f14; -fx-max-width: 45; -fx-max-height: 45;" />
            <Label text="INITIALIZING SYSTEM" styleClass="text-secondary"
                   style="-fx-font-size: 14px; -fx-font-weight: 900; -fx-letter-spacing: 5px;" />
        </VBox>
    </StackPane>
</StackPane>